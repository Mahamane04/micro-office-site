{# Rounded image card (Augment-style). Vars: fImgSrc, fImgAlt, fRatio (aspect class), fDark (unused, kept for compat), fLabel (optional badge revealed on hover), fRadius (optional radius class) #}
<div class="group relative {{ fRatio | default('aspect-[4/5]') }} overflow-hidden {{ fRadius | default('rounded-3xl') }} bg-anthracite/5">
  <img src="{{ fImgSrc }}" alt="{{ fImgAlt }}" loading="lazy" class="h-full w-full object-cover transition-transform duration-[600ms] ease-out group-hover:scale-[1.05]">
  {% if fLabel %}
  <span class="pointer-events-none absolute bottom-4 left-4 translate-y-2 rounded-full bg-white/90 px-4 py-1.5 font-heading text-xs font-semibold text-ink opacity-0 shadow-soft backdrop-blur transition-all duration-300 group-hover:translate-y-0 group-hover:opacity-100">{{ fLabel }}</span>
  {% endif %}
</div>
