---
import Base from '@layouts/Base.astro';
---

<Base
  title="Contact | Micro Office"
  description="Contactez Micro Office pour vos projets numériques. Nous répondons dans les 24h."
>
  <section class="section-pad bg-gradient-to-b from-white to-offwhite">
    <div class="container-content">
      <div class="max-w-2xl">
        <p class="eyebrow">Contact</p>
        <h1 class="font-heading text-4xl md:text-5xl font-bold leading-tight">
          Parlons de votre projet
        </h1>
        <p class="mt-6 text-lg text-ink/70">
          Vous avez une question ? Vous souhaitez collaborer ? Contactez-nous et nous vous répondrons dans les 24 heures.
        </p>
      </div>
    </div>
  </section>

  <section class="section-pad">
    <div class="container-content">
      <div class="grid grid-cols-1 gap-12 lg:grid-cols-2">
        <!-- Contact form -->
        <div>
          <h2 class="font-heading text-2xl font-bold mb-6">Envoyez-nous un message</h2>
          <form class="space-y-4">
            <div>
              <label for="name" class="block text-sm font-semibold mb-2">Nom</label>
              <input
                type="text"
                id="name"
                name="name"
                required
                class="w-full rounded-2xl border border-ink/20 px-4 py-3 focus:border-red focus:outline-none"
                placeholder="Votre nom"
              />
            </div>

            <div>
              <label for="email" class="block text-sm font-semibold mb-2">Email</label>
              <input
                type="email"
                id="email"
                name="email"
                required
                class="w-full rounded-2xl border border-ink/20 px-4 py-3 focus:border-red focus:outline-none"
                placeholder="vous@exemple.com"
              />
            </div>

            <div>
              <label for="phone" class="block text-sm font-semibold mb-2">Téléphone</label>
              <input
                type="tel"
                id="phone"
                name="phone"
                class="w-full rounded-2xl border border-ink/20 px-4 py-3 focus:border-red focus:outline-none"
                placeholder="+223 XX XX XX XX"
              />
            </div>

            <div>
              <label for="subject" class="block text-sm font-semibold mb-2">Sujet</label>
              <input
                type="text"
                id="subject"
                name="subject"
                required
                class="w-full rounded-2xl border border-ink/20 px-4 py-3 focus:border-red focus:outline-none"
                placeholder="Sujet de votre message"
              />
            </div>

            <div>
              <label for="message" class="block text-sm font-semibold mb-2">Message</label>
              <textarea
                id="message"
                name="message"
                required
                rows="6"
                class="w-full rounded-2xl border border-ink/20 px-4 py-3 focus:border-red focus:outline-none resize-none"
                placeholder="Décrivez votre projet..."
              ></textarea>
            </div>

            <button type="submit" class="btn-primary w-full">
              Envoyer le message
            </button>
          </form>
        </div>

        <!-- Contact info -->
        <div>
          <h2 class="font-heading text-2xl font-bold mb-6">Informations</h2>

          <div class="space-y-8">
            <div>
              <h3 class="font-heading font-semibold mb-2">Email</h3>
              <a href="mailto:contact@microofficeml.com" class="text-red hover:text-red-dark transition-colors">
                contact@microofficeml.com
              </a>
            </div>

            <div>
              <h3 class="font-heading font-semibold mb-2">Téléphone</h3>
              <a href="tel:+223XXXXXXXX" class="text-red hover:text-red-dark transition-colors">
                +223 XX XX XX XX
              </a>
            </div>

            <div>
              <h3 class="font-heading font-semibold mb-2">Localisation</h3>
              <p class="text-ink/70">
                Bamako, Mali
              </p>
            </div>

            <div>
              <h3 class="font-heading font-semibold mb-2">Réseaux sociaux</h3>
              <div class="flex gap-4">
                <a href="#" class="inline-flex items-center justify-center w-10 h-10 rounded-full border border-ink/20 hover:border-red hover:text-red transition-colors">
                  <span class="sr-only">LinkedIn</span>
                  <svg class="w-5 h-5" fill="currentColor" viewBox="0 0 24 24">
                    <path d="M19 0h-14c-2.761 0-5 2.239-5 5v14c0 2.761 2.239 5 5 5h14c2.762 0 5-2.239 5-5v-14c0-2.761-2.238-5-5-5zm-11 19h-3v-11h3v11zm-1.5-12.268c-.966 0-1.75-.79-1.75-1.764s.784-1.764 1.75-1.764 1.75.79 1.75 1.764-.783 1.764-1.75 1.764zm13.5 12.268h-3v-5.604c0-3.368-4-3.113-4 0v5.604h-3v-11h3v1.765c1.396-2.586 7-2.777 7 2.476v6.759z"/>
                  </svg>
                </a>
                <a href="#" class="inline-flex items-center justify-center w-10 h-10 rounded-full border border-ink/20 hover:border-red hover:text-red transition-colors">
                  <span class="sr-only">Twitter</span>
                  <svg class="w-5 h-5" fill="currentColor" viewBox="0 0 24 24">
                    <path d="M23 3a10.9 10.9 0 01-3.14 1.53 4.48 4.48 0 00-7.86 3v1A10.66 10.66 0 013 4s-4 9 5 13a11.64 11.64 0 01-7 2s9 5 20 5a9.5 9.5 0 00-9-5.5c4.75 2.25 7-7 7-7z"/>
                  </svg>
                </a>
                <a href="#" class="inline-flex items-center justify-center w-10 h-10 rounded-full border border-ink/20 hover:border-red hover:text-red transition-colors">
                  <span class="sr-only">Instagram</span>
                  <svg class="w-5 h-5" fill="currentColor" viewBox="0 0 24 24">
                    <rect x="2" y="2" width="20" height="20" rx="5" ry="5" fill="none" stroke="currentColor" stroke-width="2"/>
                    <path d="M16 11.37A4 4 0 1112.63 8 4 4 0 0116 11.37z" fill="currentColor"/>
                    <circle cx="17.5" cy="6.5" r="1.5" fill="currentColor"/>
                  </svg>
                </a>
              </div>
            </div>
          </div>
        </div>
      </div>
    </div>
  </section>
</Base>
