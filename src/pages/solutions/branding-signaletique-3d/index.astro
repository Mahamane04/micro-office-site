---
import Base from '@layouts/Base.astro';
import MotifArc from '@components/MotifArc.astro';
import FramedImage from '@components/FramedImage.astro';
import CtaBand from '@components/CtaBand.astro';
import { loadSolutionPage, loadAccueil } from '@lib/data';

const { page, prestations } = await loadSolutionPage('branding-signaletique-3d');
const accueil = await loadAccueil();
// Same Airtable image as the /solutions/ listing card ('solution-branding'), so both stay identical
const heroImage = accueil.solutions['solution-branding']?.image || '/images/portfolio/solution-branding.jpg';
// "Notre différence" before/after — same 'diff-2' (façade) pair as the homepage, from Airtable
const diff = accueil.diffs.find((d) => d.cle === 'diff-2');
const diffAvant = diff?.a || '/images/portfolio/diff-2a.jpg';
const diffApres = diff?.b || '/images/portfolio/diff-2b.jpg';
---

<Base
  title="Signalétique intérieure et extérieure, visualisation 3D de projet au Mali"
  description="Création de logo, signalétique intérieure et extérieure, habillage de façades, création de packaging et modélisation 3D de produit par Micro Office, agence de branding à Bamako."
>
  <section class="relative overflow-hidden section-pad pb-12">
    <MotifArc position="right-[-4rem] top-[-4rem] text-ink" />
    <div class="container-content relative grid grid-cols-1 gap-12 lg:grid-cols-12 lg:items-center">
      <div class="lg:col-span-6">
        <p class="eyebrow"><a href="/solutions/" class="hover:underline">Solutions</a> — 01</p>
        <h1 class="font-heading text-4xl font-bold leading-tight md:text-5xl">{page?.titreH1}</h1>
        <p class="mt-6 text-lg leading-relaxed text-ink/70">{page?.intro}</p>
        <a href="/presenter-mon-projet/" class="btn-primary mt-8">{page?.texteBouton}</a>
      </div>
      <div class="lg:col-span-6">
        <FramedImage src={heroImage} alt={page?.titreH1 || 'Branding, signalétique & visualisation 3D'} ratio="aspect-[4/3]" />
      </div>
    </div>
  </section>

  <section class="section-pad border-t border-ink/10">
    <div class="container-content">
      <h2 class="font-heading text-2xl font-bold md:text-3xl">Nos prestations</h2>
      <div class="mt-10 grid grid-cols-1 gap-x-10 gap-y-8 sm:grid-cols-2">
        {prestations.map((it) => (
          <div class="border-t border-ink/10 pt-5">
            <h3 class="font-heading text-base font-semibold">{it.titre}</h3>
            <p class="mt-2 text-sm text-ink/60">{it.description}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <section class="relative overflow-hidden bg-ink text-offwhite section-pad">
    <MotifArc position="right-0 bottom-0 text-white" />
    <div class="container-content relative">
      <p class="eyebrow">Notre différence</p>
      <h2 class="max-w-xl font-heading text-2xl font-bold leading-tight text-white md:text-3xl">Voyez le résultat avant de produire.</h2>
      <p class="mt-5 max-w-xl text-offwhite/70">Grâce à la visualisation 3D, examinez les proportions, les couleurs, les matières et l'intégration de votre projet avant sa fabrication ou son installation.</p>
      <div class="mt-10 grid grid-cols-2 gap-2 sm:max-w-xl">
        <FramedImage src={diffAvant} alt="Façade avant intervention" ratio="aspect-square" />
        <FramedImage src={diffApres} alt="Façade brandée et terminée" ratio="aspect-square" />
      </div>
    </div>
  </section>

  <CtaBand title={page?.ctaTitre} text={page?.ctaTexte} />
</Base>
