---
import Base from '@layouts/Base.astro';
import MotifArc from '@components/MotifArc.astro';
import MotifDiagonal from '@components/MotifDiagonal.astro';
import FramedImage from '@components/FramedImage.astro';
import PrestationIcon from '@components/PrestationIcon.astro';
import CtaBand from '@components/CtaBand.astro';
import { loadSolutionPage, loadAccueil } from '@lib/data';

export const prerender = false; // on-demand ISR — see index.astro note

const { page, prestations } = await loadSolutionPage('automatisation-ia');
const accueil = await loadAccueil();
// Same source as the /solutions/ listing card ('solution-automatisation') — shows the
// icon placeholder until the client adds an image, then both switch together.
const heroImage = accueil.solutions['solution-automatisation']?.image || '';
---

<Base
  title="Automatisation et chatbot WhatsApp pour entreprise au Mali"
  description="Chatbot WhatsApp, assistant commercial, qualification des prospects, relances automatiques : les solutions d'automatisation et d'intelligence artificielle de Micro Office."
>
  <!-- Hero -->
  <section class="relative overflow-hidden section-pad pb-12">
    <div class="pointer-events-none absolute inset-0 bg-blueprint-light [mask-image:linear-gradient(to_bottom,black,transparent_75%)]" aria-hidden="true"></div>
    <MotifArc position="right-[-4rem] top-[-4rem] text-ink" />
    <div class="container-content relative grid grid-cols-1 gap-12 lg:grid-cols-12 lg:items-center">
      <div class="lg:col-span-6">
        <p class="eyebrow"><a href="/solutions/" class="hover:underline">Solutions</a> <span class="text-red">— 04</span></p>
        <h1 class="mt-3 font-heading text-4xl font-bold leading-[1.05] md:text-5xl">{page?.titreH1}</h1>
        <p class="mt-6 max-w-lg text-lg leading-relaxed text-ink/70">{page?.intro}</p>
        <ul class="mt-8 flex flex-wrap gap-2">
          {prestations.slice(0, 4).map((it) => (
            <li class="rounded-full border border-ink/15 px-3 py-1.5 font-mono text-[11px] uppercase tracking-wider text-ink/55">{it.titre}</li>
          ))}
        </ul>
        <div class="mt-9 flex flex-wrap items-center gap-4">
          <a href="/presenter-mon-projet/" class="btn-primary">{page?.texteBouton}</a>
          <a href="/realisations/" class="font-heading text-sm font-semibold text-ink underline decoration-red decoration-2 underline-offset-4 hover:text-red">Voir nos réalisations →</a>
        </div>
      </div>
      <div class="lg:col-span-6">
        {heroImage ? (
          <FramedImage src={heroImage} alt={page?.titreH1 || 'Automatisation & intelligence artificielle'} ratio="aspect-[4/3]" />
        ) : (
          <div class="relative flex aspect-[4/3] items-center justify-center overflow-hidden rounded-3xl bg-ink">
            <MotifDiagonal position="left-[-2rem] bottom-[-2rem] text-white" />
            <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 64 64" class="h-20 w-20 text-red" fill="none" stroke="currentColor" stroke-width="1.5" aria-hidden="true">
              <path d="M18 44c0-9 6-16 14-16s14 7 14 16" stroke-linecap="round"/>
              <circle cx="32" cy="20" r="7"/>
              <path d="M14 50h36" stroke-linecap="round"/>
            </svg>
          </div>
        )}
      </div>
    </div>
  </section>

  <!-- Prestations -->
  <section class="section-pad border-t border-ink/10">
    <div class="container-content">
      <div class="max-w-2xl">
        <p class="eyebrow">Ce que nous automatisons</p>
        <h2 class="mt-3 font-heading text-3xl font-bold md:text-4xl">Nos prestations</h2>
        <p class="mt-4 text-ink/60">Moins de tâches répétitives, des réponses plus rapides — sans perdre le contact humain.</p>
      </div>
      <div class="mt-12 grid grid-cols-1 gap-5 sm:grid-cols-2 lg:grid-cols-3">
        {prestations.map((it) => (
          <article class="group relative rounded-3xl border border-ink/10 bg-white p-6 transition-all duration-300 hover:-translate-y-1 hover:border-red/40 hover:shadow-soft">
            <div class="flex h-12 w-12 items-center justify-center rounded-2xl bg-ink text-white transition-colors duration-300 group-hover:bg-red">
              <PrestationIcon label={it.titre} class="h-6 w-6" />
            </div>
            <h3 class="mt-5 font-heading text-lg font-bold group-hover:text-red">{it.titre}</h3>
            <p class="mt-2 text-sm leading-relaxed text-ink/60">{it.description}</p>
          </article>
        ))}
      </div>
    </div>
  </section>

  <CtaBand title={page?.ctaTitre} text={page?.ctaTexte} />
</Base>
