---
import Base from '@layouts/Base.astro';
import MotifArc from '@components/MotifArc.astro';
import FramedImage from '@components/FramedImage.astro';
import CtaBand from '@components/CtaBand.astro';
import { loadSolutionPage, loadAccueil } from '@lib/data';

const { page, prestations } = await loadSolutionPage('sites-web-applications-gestion');
const accueil = await loadAccueil();
const heroImage = accueil.solutions['solution-web']?.image || '/images/portfolio/solution-web.jpg';
---

<Base
  title="Création de site internet, application mobile et gestion au Mali"
  description="Sites de présentation, sites e-commerce, applications, portails clients, gestion des commandes et des stocks : les solutions digitales de Micro Office au Mali."
>
  <section class="relative overflow-hidden section-pad pb-12">
    <MotifArc position="right-[-4rem] top-[-4rem] text-ink" />
    <div class="container-content relative grid grid-cols-1 gap-12 lg:grid-cols-12 lg:items-center">
      <div class="lg:col-span-6">
        <p class="eyebrow"><a href="/solutions/" class="hover:underline">Solutions</a> — 03</p>
        <h1 class="font-heading text-4xl font-bold leading-tight md:text-5xl">{page?.titreH1}</h1>
        <p class="mt-6 text-lg leading-relaxed text-ink/70">{page?.intro}</p>
        <a href="/presenter-mon-projet/" class="btn-primary mt-8">{page?.texteBouton}</a>
      </div>
      <div class="lg:col-span-6">
        <FramedImage src={heroImage} alt={page?.titreH1 || 'Sites web, applications & solutions de gestion'} ratio="aspect-[4/3]" />
      </div>
    </div>
  </section>

  <section class="section-pad border-t border-ink/10">
    <div class="container-content">
      <h2 class="font-heading text-2xl font-bold md:text-3xl">Nos prestations</h2>
      <div class="mt-10 grid grid-cols-1 gap-x-10 gap-y-8 sm:grid-cols-2">
        {prestations.map((it) => (
          <div class="border-t border-ink/10 pt-5">
            <h3 class="font-heading text-base font-semibold">{it.titre}</h3>
            <p class="mt-2 text-sm text-ink/60">{it.description}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <CtaBand title={page?.ctaTitre} text={page?.ctaTexte} />
</Base>
