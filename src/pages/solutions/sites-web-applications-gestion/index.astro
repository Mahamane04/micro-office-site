---
import Base from '@layouts/Base.astro';
import MotifArc from '@components/MotifArc.astro';
import FramedImage from '@components/FramedImage.astro';
import CtaBand from '@components/CtaBand.astro';

const items = [
  { t: 'Sites de présentation', d: 'Un site clair pour présenter votre activité et générer des contacts.' },
  { t: 'Sites e-commerce', d: 'Une boutique en ligne pour vendre vos produits.' },
  { t: 'Applications', d: 'Une application mobile adaptée à vos usages métier.' },
  { t: 'Portails clients', d: 'Un espace dédié pour vos clients ou partenaires.' },
  { t: 'Gestion des clients', d: 'Un suivi centralisé de votre relation client.' },
  { t: 'Commandes', d: 'Un processus de commande simple et fiable.' },
  { t: 'Paiements', d: 'Des solutions de paiement adaptées à votre marché.' },
  { t: 'Stocks', d: 'Un suivi précis de vos stocks et de vos produits.' },
  { t: 'Tableaux de bord', d: 'Une vision claire de votre activité, en temps réel.' },
];
---

<Base
  title="Création de site internet, application mobile et gestion au Mali"
  description="Sites de présentation, sites e-commerce, applications, portails clients, gestion des commandes et des stocks : les solutions digitales de Micro Office au Mali."
>
  <section class="relative overflow-hidden section-pad pb-12">
    <MotifArc position="right-[-4rem] top-[-4rem] text-ink" />
    <div class="container-content relative grid grid-cols-1 gap-12 lg:grid-cols-12 lg:items-center">
      <div class="lg:col-span-6">
        <p class="eyebrow"><a href="/solutions/" class="hover:underline">Solutions</a> — 03</p>
        <h1 class="font-heading text-4xl font-bold leading-tight md:text-5xl">Sites web, applications &amp; solutions de gestion</h1>
        <p class="mt-6 text-lg leading-relaxed text-ink/70">Présentez votre entreprise, facilitez l'accès à vos services et centralisez les informations importantes de votre activité.</p>
        <a href="/presenter-mon-projet/" class="btn-primary mt-8">Créer ma solution digitale</a>
      </div>
      <div class="lg:col-span-6">
        <FramedImage src="/images/portfolio/solution-web.jpg" alt="Supports digitaux et site web Micro Office" ratio="aspect-[4/3]" />
      </div>
    </div>
  </section>

  <section class="section-pad border-t border-ink/10">
    <div class="container-content">
      <h2 class="font-heading text-2xl font-bold md:text-3xl">Nos prestations</h2>
      <div class="mt-10 grid grid-cols-1 gap-x-10 gap-y-8 sm:grid-cols-2">
        {items.map((it) => (
          <div class="border-t border-ink/10 pt-5">
            <h3 class="font-heading text-base font-semibold">{it.t}</h3>
            <p class="mt-2 text-sm text-ink/60">{it.d}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <CtaBand
    title="Un site, une application ou un outil de gestion en tête ?"
    text="Décrivez votre activité et vos besoins : nous vous proposons la solution digitale la plus adaptée."
  />
</Base>
