---
import Base from '@layouts/Base.astro';
import MotifArc from '@components/MotifArc.astro';
import FramedImage from '@components/FramedImage.astro';
import Lightbox from '@components/Lightbox.astro';
import CtaBand from '@components/CtaBand.astro';
import { loadAllProjets } from '@lib/data';
import { smartCrop, isCloudinaryUrl } from '@lib/cloudinary';

export const prerender = false; // on-demand ISR — see index.astro note

const projets = await loadAllProjets();
// Filter by clean families (from Airtable "Famille"), fallback to raw categories
const familles = [...new Set(projets.flatMap((p) => (p.familles.length ? p.familles : p.categories)))].sort();

// One lightweight thumbnail per project: Cloudinary smart-crop variants at 4:3.
// Grid columns cap around ~420px wide, so 480/768/1024 covers 1x/2x densities.
const coverSrcset = (url: string) =>
  isCloudinaryUrl(url)
    ? [480, 768, 1024].map((w) => `${smartCrop(url, w, Math.round((w * 3) / 4))} ${w}w`).join(', ')
    : undefined;
const coverSizes = '(min-width: 1024px) 33vw, (min-width: 640px) 50vw, 100vw';
---

<Base
  title="Réalisations : branding, signalétique, 3D et digital au Mali"
  description="Découvrez les réalisations de Micro Office : branding, signalétique, visualisation 3D et supports digitaux au Mali."
>
  <section class="relative overflow-hidden section-pad pb-10">
    <div class="pointer-events-none absolute inset-0 bg-blueprint-light [mask-image:linear-gradient(to_bottom,black,transparent_80%)]" aria-hidden="true"></div>
    <MotifArc position="right-[-4rem] top-[-4rem] text-ink" />
    <div class="container-content relative">
      <div class="max-w-2xl">
        <p class="eyebrow">Réalisations</p>
        <h1 class="font-heading text-4xl font-bold leading-tight md:text-5xl">Des idées devenues réalité.</h1>
        <p class="mt-6 text-lg leading-relaxed text-ink/70">
          Découvrez comment nous avons accompagné nos clients depuis leur besoin initial jusqu'à la réalisation finale.
        </p>
      </div>
    </div>
  </section>

  <section class="section-pad pt-6">
    <div class="container-content">
      {/* Filters */}
      <div class="flex flex-col gap-6 border-t border-ink/10 pt-8 lg:flex-row lg:items-center lg:justify-between">
        <div class="flex flex-wrap gap-2" role="group" aria-label="Filtrer par catégorie">
          <button type="button" data-filter="all" class="filter-btn is-active border border-ink px-4 py-2 font-mono text-[11px] uppercase tracking-[0.15em] transition-colors">Tous</button>
          {familles.map((fam) => (
            <button type="button" data-filter={fam} class="filter-btn border border-ink/20 px-4 py-2 font-mono text-[11px] uppercase tracking-[0.15em] text-ink/70 transition-colors">{fam}</button>
          ))}
        </div>

        <div class="flex shrink-0 items-center gap-3">
          <span class="font-mono text-[11px] uppercase tracking-[0.15em] text-ink/50">Trier</span>
          <select id="portfolio-sort" class="rounded-full border border-ink/20 bg-white px-4 py-2 font-mono text-[11px] uppercase tracking-[0.15em] text-ink transition-colors hover:border-ink focus:border-red focus:outline-none">
            <option value="default">Par défaut</option>
            <option value="az">A → Z</option>
          </select>
        </div>
      </div>

      {/* Cards grid */}
      <div id="portfolio-grid" class="mt-12 grid grid-cols-1 gap-x-8 gap-y-14 sm:grid-cols-2 lg:grid-cols-3">
        {projets.map((p, i) => (
          <article class="portfolio-card" data-categories={(p.familles.length ? p.familles : p.categories).join('|')} data-title={p.titre}>
            <button
              type="button"
              class="group block w-full rounded-3xl text-left focus-visible:outline focus-visible:outline-2 focus-visible:outline-offset-2 focus-visible:outline-red"
              data-lightbox-open
              data-slug={p.slug}
              data-titre={p.titre}
              data-categorie={p.familles[0] || p.categories[0] || ''}
              aria-label={`Ouvrir la galerie du projet ${p.titre}`}
            >
              <FramedImage
                src={isCloudinaryUrl(p.couverture) ? smartCrop(p.couverture, 768, 576) : p.couverture}
                srcset={coverSrcset(p.couverture)}
                sizes={coverSizes}
                width={768}
                height={576}
                alt={`Couverture du projet ${p.titre}`}
                ratio="aspect-[4/3]"
                label="Voir la galerie →"
                eager={i === 0}
              />
            </button>
            {(p.familles[0] || p.categories[0]) && <p class="tag-mono mt-5 text-red">{p.familles[0] || p.categories[0]}</p>}
            <a href={`/realisations/${p.slug}/`} class="group block">
              <h2 class="mt-2 font-heading text-lg font-bold group-hover:text-red">{p.titre}</h2>
            </a>
            {p.client && <p class="tag-mono mt-1 text-ink/40">Client — {p.client}</p>}
            {p.accroche && <p class="mt-2 text-sm text-ink/60">{p.accroche}</p>}
            {!p.accroche && p.nombreImages > 0 && (
              <p class="mt-2 text-sm text-ink/60">{p.nombreImages} image{p.nombreImages > 1 ? 's' : ''}</p>
            )}
          </article>
        ))}
      </div>

      <p id="portfolio-empty" class="mt-12 hidden border-l-2 border-red pl-6 text-ink/60">Aucun projet dans cette catégorie pour le moment.</p>
    </div>
  </section>

  <CtaBand />
  <Lightbox />
</Base>

<script>
  const filterBtns = document.querySelectorAll<HTMLButtonElement>('.filter-btn');
  const sortSelect = document.getElementById('portfolio-sort') as HTMLSelectElement | null;
  const grid = document.getElementById('portfolio-grid');
  const empty = document.getElementById('portfolio-empty');
  const cards = Array.from(document.querySelectorAll<HTMLElement>('.portfolio-card'));
  const originalOrder = [...cards];

  function apply() {
    const active = document.querySelector<HTMLButtonElement>('.filter-btn.is-active')?.dataset.filter || 'all';
    const sort = sortSelect?.value || 'default';

    let visible = cards.filter((card) => {
      if (active === 'all') return true;
      const cats = (card.dataset.categories || '').split('|');
      return cats.includes(active);
    });

    if (sort === 'az') {
      visible = [...visible].sort((a, b) =>
        (a.dataset.title || '').localeCompare(b.dataset.title || '', 'fr')
      );
    } else {
      visible = originalOrder.filter((c) => visible.includes(c));
    }

    cards.forEach((c) => (c.style.display = 'none'));
    visible.forEach((c) => {
      c.style.display = '';
      grid?.appendChild(c);
    });

    empty?.classList.toggle('hidden', visible.length > 0);
  }

  filterBtns.forEach((btn) => {
    btn.addEventListener('click', () => {
      filterBtns.forEach((b) => {
        b.classList.remove('is-active', 'border-ink');
        b.classList.add('border-ink/20', 'text-ink/70');
      });
      btn.classList.add('is-active', 'border-ink');
      btn.classList.remove('border-ink/20', 'text-ink/70');
      apply();
    });
  });

  sortSelect?.addEventListener('change', apply);
</script>
