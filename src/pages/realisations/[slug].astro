---
import Base from '@layouts/Base.astro';
import MotifArc from '@components/MotifArc.astro';
import FramedImage from '@components/FramedImage.astro';
import CtaBand from '@components/CtaBand.astro';
import { loadAllProjets, loadProjetBySlug, loadImagesForProjet } from '@lib/data';

export const prerender = false; // On-demand ISR

export async function getStaticPaths() {
  const projets = await loadAllProjets();
  return projets.map((p) => ({ params: { slug: p.slug } }));
}

const { slug } = Astro.params;
const projet = await loadProjetBySlug(slug!);

if (!projet) {
  return Astro.redirect('/realisations/');
}

const images = await loadImagesForProjet(projet);
const primaryCategory = projet.categories[0] || '';
---

<Base
  title={`${projet.titre} — Réalisation Micro Office`}
  description={projet.accroche || `${projet.titre} — réalisation Micro Office`}
  ogImage={projet.couverture}
>
  <section class="relative overflow-hidden section-pad pb-10">
    <MotifArc position="right-[-4rem] top-[-4rem] text-ink" />
    <div class="container-content relative">
      <div>
        <a href="/realisations/" class="tag-mono inline-flex items-center gap-2 text-ink/50 hover:text-red">← Toutes les réalisations</a>
      </div>

      {primaryCategory && <p class="eyebrow mt-8">{primaryCategory}</p>}
      <h1 class="max-w-3xl font-heading text-4xl font-bold leading-tight md:text-5xl">{projet.titre}</h1>

      <div class="mt-6 flex flex-wrap gap-x-10 gap-y-2">
        {projet.client && (
          <p class="tag-mono text-ink/50">Client — <span class="text-ink">{projet.client}</span></p>
        )}
        {projet.categories.length > 0 && (
          <p class="tag-mono text-ink/50">Catégorie — <span class="text-ink">{projet.categories.join(', ')}</span></p>
        )}
        {projet.nombreImages > 0 && (
          <p class="tag-mono text-ink/50">Images — <span class="text-ink">{projet.nombreImages}</span></p>
        )}
      </div>

      {projet.description && (
        <p class="mt-8 max-w-2xl text-lg leading-relaxed text-ink/70">{projet.description}</p>
      )}
    </div>
  </section>

  {images.length > 0 && (
    <section class="section-pad pt-4">
      <div class="container-content">
        <div class:list={['grid grid-cols-1 gap-3', images.length > 1 && 'sm:grid-cols-2']}>
          {images.map((img) => (
            <FramedImage src={img.url} alt={img.nom || projet.titre} ratio="aspect-[4/3]" />
          ))}
        </div>
      </div>
    </section>
  )}

  {images.length === 0 && projet.couverture && (
    <section class="section-pad pt-4">
      <div class="container-content">
        <FramedImage src={projet.couverture} alt={projet.titre} ratio="aspect-[16/9]" />
      </div>
    </section>
  )}

  <CtaBand
    title="Un projet similaire en tête ?"
    text="Décrivez votre besoin : nous vous montrons à quoi votre projet peut ressembler avant de le réaliser."
  />
</Base>
