---
import Base from '@layouts/Base.astro';
---

<Base title="Page non trouvée" description="La page que vous cherchez n'existe pas.">
  <section class="section-pad">
    <div class="container-content text-center">
      <div class="max-w-md mx-auto">
        <div class="text-6xl font-bold text-red mb-4">404</div>
        <h1 class="font-heading text-3xl font-bold mb-4">Page non trouvée</h1>
        <p class="text-ink/70 mb-8">
          Désolé, la page que vous cherchez n'existe pas ou a été déplacée.
        </p>
        <a href="/" class="btn-primary">Retour à l'accueil</a>
      </div>
    </div>
  </section>
</Base>
