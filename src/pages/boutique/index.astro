---
import Base from '@layouts/Base.astro';
import { loadAllProduits } from '@lib/produits';
import { uniqueCategories, sortBy } from '@lib/filters';

export const prerender = false; // on-demand ISR — see index.astro note

const produits = await loadAllProduits();
const categories = uniqueCategories(produits);

// Sort by featured first, then alphabetically
const produitsTriés = sortBy(
  produits.sort((a, b) => (b.misEnAvant ? 1 : 0) - (a.misEnAvant ? 1 : 0)),
  'nom'
);
---

<Base
  title="Boutique | Micro Office"
  description="Découvrez notre sélection d'articles de qualité. Paiement à la livraison ou par mobile money."
>
  <!-- Hero section -->
  <section class="section-pad bg-gradient-to-b from-white to-offwhite">
    <div class="container-content">
      <div class="max-w-2xl">
        <p class="eyebrow">Boutique</p>
        <h1 class="font-heading text-4xl md:text-5xl font-bold leading-tight">
          Nos articles, livrés chez vous.
        </h1>
        <p class="mt-6 text-lg text-ink/70">
          Parcourez notre sélection, ajoutez au panier et commandez en quelques secondes.
          <span class="text-ink">Paiement à la livraison</span> ou par mobile money — sans paiement en ligne.
        </p>
      </div>
    </div>
  </section>

  <!-- Products section -->
  <section class="section-pad">
    <div class="container-content">
      <!-- Search & Filters -->
      <div class="mb-12">
        <div class="flex flex-col lg:flex-row lg:items-center lg:justify-between gap-6 mb-8">
          <!-- Search -->
          <div class="relative flex-1">
            <svg
              class="pointer-events-none absolute left-4 top-1/2 h-5 w-5 -translate-y-1/2 text-ink/40"
              viewBox="0 0 24 24"
              fill="none"
              stroke="currentColor"
              stroke-width="2"
              stroke-linecap="round"
              stroke-linejoin="round"
              aria-hidden="true"
            >
              <circle cx="11" cy="11" r="7"></circle>
              <path d="m20 20-3.5-3.5"></path>
            </svg>
            <input
              type="search"
              placeholder="Rechercher un produit, une marque…"
              aria-label="Rechercher un produit"
              class="w-full rounded-full border border-ink/15 bg-white py-3.5 pl-12 pr-4 text-ink shadow-[0_1px_2px_rgba(0,0,0,0.04)] focus:border-red focus:outline-none"
            />
          </div>

          <!-- Sort -->
          <div class="flex items-center gap-3">
            <span class="font-mono text-[11px] uppercase tracking-widest text-ink/50">Trier</span>
            <select class="rounded-lg border border-ink/20 px-4 py-2 text-sm focus:border-red focus:outline-none">
              <option value="featured">Populaires</option>
              <option value="price-asc">Prix croissant</option>
              <option value="price-desc">Prix décroissant</option>
              <option value="az">A → Z</option>
            </select>
          </div>
        </div>

        <!-- Category filters -->
        <div class="flex flex-wrap gap-2" role="group" aria-label="Filtrer par catégorie">
          <button
            type="button"
            class="filter-btn is-active border border-ink px-4 py-2 font-mono text-[11px] uppercase tracking-[0.15em] transition-colors"
            data-filter="all"
          >
            Tous ({produits.length})
          </button>
          {
            categories.map((cat) => (
              <button
                type="button"
                class="filter-btn border border-ink/20 px-4 py-2 font-mono text-[11px] uppercase tracking-[0.15em] text-ink/70 transition-colors"
                data-filter={cat}
              >
                {cat} ({produits.filter((p) => p.categorie === cat).length})
              </button>
            ))
          }
        </div>
      </div>

      <!-- Products Grid -->
      <div id="boutique-grid" class="grid grid-cols-1 gap-6 sm:grid-cols-2 lg:grid-cols-3 xl:grid-cols-4">
        {
          produitsTriés.map((p) => (
            <article
              class="product-card group border border-ink/10 rounded-2xl overflow-hidden hover:border-red transition-colors"
              data-slug={p.slug}
              data-category={p.categorie}
              data-name={p.nom}
              data-price={p.prixPromo || p.prix}
              data-featured={p.misEnAvant ? '1' : '0'}
            >
              <div class="relative overflow-hidden bg-offwhite">
                <a href={`/boutique/${p.slug}/`} class="block">
                  <img
                    src={p.couverture}
                    alt={p.nom}
                    loading="lazy"
                    class="w-full aspect-square object-cover group-hover:scale-105 transition-transform duration-300"
                  />
                </a>
                {p.statut === 'rupture' && (
                  <span class="product-badge product-badge-out">Rupture</span>
                )}
                {p.nouveaute && <span class="product-badge product-badge-new">Nouveau</span>}
              </div>

              <div class="p-4">
                <a href={`/boutique/${p.slug}/`} class="block">
                  <h3 class="font-heading font-semibold text-lg text-ink group-hover:text-red transition-colors truncate">
                    {p.nom}
                  </h3>
                </a>
                <p class="text-sm text-ink/50 truncate">{p.marque}</p>

                <div class="mt-3 flex items-baseline gap-2">
                  <span class="font-heading font-bold text-xl" data-price-xof={p.prixPromo || p.prix}>
                    {p.prixPromo || p.prix} FCFA
                  </span>
                  {p.prixPromo && (
                    <span class="text-sm font-medium text-ink/40 line-through">
                      {p.prix} FCFA
                    </span>
                  )}
                </div>

                <a href={`/boutique/${p.slug}/`} class="btn-primary w-full mt-4 text-center">
                  Voir le produit
                </a>
              </div>
            </article>
          ))
        }
      </div>

      <!-- Empty state -->
      <p id="boutique-empty" class="hidden mt-12 text-center text-ink/60">
        Aucun article dans cette catégorie pour le moment.
      </p>
    </div>
  </section>
</Base>

<style>
  .filter-btn.is-active {
    @apply border-ink bg-ink text-white;
  }

  .product-badge {
    @apply absolute top-3 right-3 px-3 py-1.5 rounded-lg text-xs font-semibold text-white bg-ink;
  }

  .product-badge-new {
    @apply bg-green-500;
  }

  .product-badge-out {
    @apply bg-red;
  }
</style>

<script>
  // Client-side filtering and sorting
  const filterBtns = document.querySelectorAll('.filter-btn');
  const sortSelect = document.querySelector('select');
  const grid = document.getElementById('boutique-grid');
  const emptyState = document.getElementById('boutique-empty');

  function updateDisplay() {
    const activeFilter = document.querySelector('.filter-btn.is-active')?.dataset.filter || 'all';
    const sortBy = sortSelect?.value || 'featured';

    const cards = Array.from(document.querySelectorAll('.product-card')) as HTMLElement[];

    let visibleCards = cards.filter((card) => {
      const category = card.dataset.category;
      return activeFilter === 'all' || category === activeFilter;
    });

    // Sort
    visibleCards.sort((a, b) => {
      switch (sortBy) {
        case 'price-asc':
          return Number(a.dataset.price) - Number(b.dataset.price);
        case 'price-desc':
          return Number(b.dataset.price) - Number(a.dataset.price);
        case 'az':
          return (a.dataset.name || '').localeCompare(b.dataset.name || '');
        case 'featured':
        default:
          return Number(b.dataset.featured) - Number(a.dataset.featured);
      }
    });

    // Update display
    grid?.replaceChildren(...visibleCards);

    if (visibleCards.length === 0) {
      emptyState?.classList.remove('hidden');
    } else {
      emptyState?.classList.add('hidden');
    }
  }

  filterBtns.forEach((btn) => {
    btn.addEventListener('click', () => {
      filterBtns.forEach((b) => b.classList.remove('is-active'));
      btn.classList.add('is-active');
      updateDisplay();
    });
  });

  sortSelect?.addEventListener('change', updateDisplay);
</script>
