---
import Base from '@layouts/Base.astro';
import { loadAllProduits, loadProduitBySlug } from '@lib/data';
import { buildCloudinaryUrl } from '@lib/cloudinary';
import { others } from '@lib/filters';

export const prerender = false; // On-demand ISR

export async function getStaticPaths() {
  const produits = await loadAllProduits();
  return produits.map((p) => ({ params: { slug: p.slug }, props: { product: p } }));
}

const { slug } = Astro.params;
const product = await loadProduitBySlug(slug!);

if (!product) {
  return Astro.redirect('/boutique/');
}

const allProducts = await loadAllProduits();
const relatedProducts = others(allProducts, product.slug, 4);

const title = `${product.nom} — ${product.marque} | Boutique Micro Office`;
const description = product.accroche;
const ogImage = product.couverture;
---

<Base
  title={title}
  description={description}
  ogImage={ogImage}
  canonical={`https://www.microofficeml.com/boutique/${product.slug}/`}
>
  <section class="section-pad pb-10">
    <div class="container-content">
      <!-- Back link -->
      <div class="mb-8">
        <a href="/boutique/" class="inline-flex items-center gap-2 text-sm font-medium text-ink/50 hover:text-red transition-colors">
          ← Retour à la boutique
        </a>
      </div>

      <!-- Product detail -->
      <div
        class="grid grid-cols-1 gap-10 lg:grid-cols-2 lg:gap-14"
        data-product-detail
        data-slug={product.slug}
        data-nom={product.nom}
        data-prix={product.prixPromo || product.prix}
        data-image={product.couverture}
        data-statut={product.statut}
      >
        <!-- Gallery -->
        <div>
          <div class="relative flex aspect-square items-center justify-center overflow-hidden rounded-4xl border border-ink/10 bg-offwhite">
            <img
              id="product-main-image"
              src={product.couverture}
              alt={product.nom}
              class="h-full w-full object-contain p-6"
              loading="eager"
            />
            {product.statut === 'rupture' && <span class="product-badge product-badge-out">Rupture</span>}
            {product.nouveaute && <span class="product-badge product-badge-new">Nouveau</span>}
          </div>

          <!-- Thumbnails -->
          {
            product.images && product.images.length > 1 && (
              <div class="mt-3 flex gap-3">
                {product.images.map((img) => (
                  <button
                    type="button"
                    class="flex aspect-square w-20 items-center justify-center overflow-hidden rounded-2xl border border-ink/10 bg-offwhite transition-colors hover:border-red"
                    data-thumb={img.src}
                  >
                    <img src={img.src} alt={img.alt} class="h-full w-full object-contain p-1.5" loading="lazy" />
                  </button>
                ))}
              </div>
            )
          }
        </div>

        <!-- Info -->
        <div>
          <p class="eyebrow">{product.categorie}</p>
          <h1 class="mt-2 font-heading text-3xl md:text-4xl font-bold leading-tight">{product.nom}</h1>
          <p class="mt-2 text-lg text-ink/50">{product.marque}</p>

          <!-- Price -->
          <p class="mt-6 flex items-baseline gap-3 font-heading text-3xl font-bold">
            <span data-price-xof={product.prixPromo || product.prix}>
              {(product.prixPromo || product.prix).toLocaleString('fr-FR')} FCFA
            </span>
            {
              product.prixPromo && (
                <span class="text-xl font-medium text-ink/40 line-through" data-price-xof={product.prix}>
                  {product.prix.toLocaleString('fr-FR')} FCFA
                </span>
              )
            }
          </p>

          <!-- Stock status -->
          <div class="mt-4">
            {product.statut === 'en stock' && (
              <span class="pill">
                <span class="h-2 w-2 rounded-full bg-green-500"></span> En stock
              </span>
            )}
            {product.statut === 'sur commande' && (
              <span class="pill">
                <span class="h-2 w-2 rounded-full bg-amber-500"></span> Sur commande
              </span>
            )}
            {product.statut === 'rupture' && (
              <span class="pill">
                <span class="h-2 w-2 rounded-full bg-ink/40"></span> Rupture de stock
              </span>
            )}
          </div>

          <!-- Colors -->
          {
            product.couleurs && product.couleurs.length > 0 && (
              <div class="mt-8">
                <p class="mb-3 font-heading text-sm font-semibold">Couleur</p>
                <div class="flex flex-wrap gap-2" data-color-group>
                  {product.couleurs.map((c) => (
                    <button
                      type="button"
                      class="group relative flex h-10 w-10 items-center justify-center rounded-full border-2 border-ink/15 transition-transform hover:scale-105 disabled:cursor-not-allowed disabled:opacity-30"
                      data-color={c.nom}
                      disabled={!c.disponible}
                      title={c.nom}
                      aria-label={`Couleur ${c.nom}`}
                    >
                      <span
                        class="h-6 w-6 rounded-full ring-1 ring-inset ring-black/10"
                        style={`background-color: ${c.hex}`}
                      ></span>
                    </button>
                  ))}
                </div>
              </div>
            )
          }

          <!-- Sizes -->
          {
            product.tailles && product.tailles.length > 0 && (
              <div class="mt-8">
                <p class="mb-3 font-heading text-sm font-semibold">Taille</p>
                <div class="flex flex-wrap gap-2" data-size-group>
                  {product.tailles.map((t) => (
                    <button
                      type="button"
                      class="min-w-[3rem] rounded-full border border-ink/20 px-4 py-2 font-mono text-[12px] uppercase tracking-wider transition-colors hover:border-ink data-[selected]:border-ink data-[selected]:bg-ink data-[selected]:text-white disabled:cursor-not-allowed disabled:opacity-30 disabled:line-through"
                      data-size={t.valeur}
                      disabled={!t.disponible}
                    >
                      {t.valeur}
                    </button>
                  ))}
                </div>
                <p class="mt-2 hidden text-sm text-red font-mono" data-size-error>Veuillez choisir une taille.</p>
              </div>
            )
          }

          <!-- Quantity + actions -->
          <div class="mt-8 flex flex-wrap items-center gap-3">
            <div class="inline-flex items-center rounded-full border border-ink/20">
              <button
                type="button"
                class="flex h-11 w-11 items-center justify-center rounded-full text-lg hover:text-red"
                data-qty-minus
                aria-label="Diminuer la quantité"
              >
                −
              </button>
              <span class="w-8 text-center font-heading font-semibold" data-qty>1</span>
              <button
                type="button"
                class="flex h-11 w-11 items-center justify-center rounded-full text-lg hover:text-red"
                data-qty-plus
                aria-label="Augmenter la quantité"
              >
                +
              </button>
            </div>
            <button
              type="button"
              class="btn-primary flex-1 sm:flex-none"
              data-add-detail
              disabled={product.statut === 'rupture'}
            >
              Ajouter au panier
            </button>
          </div>

          <button
            type="button"
            class="btn-secondary mt-3 w-full sm:w-auto"
            data-order-whatsapp
            disabled={product.statut === 'rupture'}
          >
            <svg class="h-4 w-4" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
              <path d="M12 2a10 10 0 0 0-8.5 15.3L2 22l4.8-1.5A10 10 0 1 0 12 2Zm5.3 14.1c-.2.6-1.3 1.2-1.8 1.2-.5.1-1 .1-1.7-.1-.4-.1-.9-.3-1.6-.6-2.7-1.2-4.5-4-4.6-4.2-.1-.2-1.1-1.5-1.1-2.8s.7-2 .9-2.2c.2-.2.5-.3.7-.3h.5c.2 0 .4 0 .6.5l.8 2c.1.2.1.3 0 .5l-.4.5-.3.3c-.1.1-.3.3-.1.5.1.3.7 1.1 1.4 1.8 1 .8 1.7 1.1 2 1.2.2.1.4.1.5-.1l.6-.7c.2-.2.3-.2.6-.1l1.9.9c.3.1.4.2.5.3 0 .2 0 .7-.2 1.3Z" />
            </svg>
            Commander sur WhatsApp
          </button>

          <p class="mt-3 hidden text-sm text-red font-mono uppercase tracking-wider" data-detail-stock></p>

          <!-- Delivery / payment info -->
          <div class="mt-8 space-y-3 rounded-3xl border border-ink/10 bg-white p-5">
            <p class="flex items-center gap-3 text-sm text-ink/70">
              <svg
                class="h-5 w-5 text-red"
                viewBox="0 0 24 24"
                fill="none"
                stroke="currentColor"
                stroke-width="1.7"
                stroke-linecap="round"
                stroke-linejoin="round"
              >
                <path d="M1 3h15v13H1z"></path>
                <path d="M16 8h4l3 3v5h-7z"></path>
                <circle cx="5.5" cy="18.5" r="2.5"></circle>
                <circle cx="18.5" cy="18.5" r="2.5"></circle>
              </svg>
              Livraison Bamako, régions et international (sur devis).
            </p>
            <p class="flex items-center gap-3 text-sm text-ink/70">
              <svg
                class="h-5 w-5 text-red"
                viewBox="0 0 24 24"
                fill="none"
                stroke="currentColor"
                stroke-width="1.7"
                stroke-linecap="round"
                stroke-linejoin="round"
              >
                <rect x="2" y="5" width="20" height="14" rx="2"></rect>
                <path d="M2 10h20"></path>
              </svg>
              Paiement à la livraison ou par mobile money.
            </p>
          </div>

          <!-- Description -->
          {
            product.description && (
              <div class="mt-8">
                <h2 class="font-heading text-lg font-bold">Description</h2>
                <p class="mt-3 leading-relaxed text-ink/70">{product.description}</p>
              </div>
            )
          }
        </div>
      </div>
    </div>
  </section>

  <!-- Related products -->
  {
    relatedProducts.length > 0 && (
      <section class="section-pad pt-4">
        <div class="container-content">
          <h2 class="font-heading text-2xl md:text-3xl font-bold">Vous aimerez aussi</h2>
          <div class="mt-8 grid grid-cols-1 gap-6 sm:grid-cols-2 lg:grid-cols-4">
            {relatedProducts.map((p) => (
              <article class="product-card group border border-ink/10 rounded-2xl overflow-hidden hover:border-red transition-colors">
                <div class="relative overflow-hidden bg-offwhite">
                  <a href={`/boutique/${p.slug}/`} class="block">
                    <img
                      src={p.couverture}
                      alt={p.nom}
                      loading="lazy"
                      class="w-full aspect-square object-cover group-hover:scale-105 transition-transform duration-300"
                    />
                  </a>
                  {p.statut === 'rupture' && (
                    <span class="product-badge product-badge-out">Rupture</span>
                  )}
                  {p.nouveaute && <span class="product-badge product-badge-new">Nouveau</span>}
                </div>

                <div class="p-4">
                  <a href={`/boutique/${p.slug}/`} class="block">
                    <h3 class="font-heading font-semibold text-lg text-ink group-hover:text-red transition-colors truncate">
                      {p.nom}
                    </h3>
                  </a>
                  <p class="text-sm text-ink/50 truncate">{p.marque}</p>

                  <div class="mt-3 flex items-baseline gap-2">
                    <span class="font-heading font-bold text-xl" data-price-xof={p.prixPromo || p.prix}>
                      {(p.prixPromo || p.prix).toLocaleString('fr-FR')} FCFA
                    </span>
                    {p.prixPromo && (
                      <span class="text-sm font-medium text-ink/40 line-through">
                        {p.prix.toLocaleString('fr-FR')} FCFA
                      </span>
                    )}
                  </div>

                  <button
                    type="button"
                    class="btn-primary w-full mt-4"
                    data-add={p.slug}
                    data-nom={p.nom}
                    data-prix={p.prixPromo || p.prix}
                    data-image={p.couverture}
                    disabled={p.statut === 'rupture'}
                  >
                    Ajouter au panier
                  </button>
                </div>
              </article>
            ))}
          </div>
        </div>
      </section>
    )
  }

  <!-- JSON-LD structured data -->
  <script type="application/ld+json" set:html={JSON.stringify({
    '@context': 'https://schema.org/',
    '@type': 'Product',
    name: product.nom,
    image: product.couverture,
    description: product.accroche,
    brand: { '@type': 'Brand', name: product.marque },
    offers: {
      '@type': 'Offer',
      priceCurrency: 'XOF',
      price: product.prixPromo || product.prix,
      availability: product.statut !== 'rupture' ? 'https://schema.org/InStock' : 'https://schema.org/OutOfStock',
      url: `https://www.microofficeml.com/boutique/${product.slug}/`,
    },
  })} />
</Base>

<style>
  .product-badge {
    @apply absolute top-3 right-3 px-3 py-1.5 rounded-lg text-xs font-semibold text-white bg-ink;
  }

  .product-badge-new {
    @apply bg-green-500;
  }

  .product-badge-out {
    @apply bg-red;
  }
</style>

<script>
  // Client-side product detail interactions
  const quantityMinus = document.querySelector('[data-qty-minus]');
  const quantityPlus = document.querySelector('[data-qty-plus]');
  const quantityDisplay = document.querySelector('[data-qty]');

  if (quantityMinus && quantityPlus && quantityDisplay) {
    quantityMinus.addEventListener('click', () => {
      const qty = Math.max(1, parseInt(quantityDisplay.textContent || '1') - 1);
      quantityDisplay.textContent = String(qty);
    });

    quantityPlus.addEventListener('click', () => {
      const qty = parseInt(quantityDisplay.textContent || '1') + 1;
      quantityDisplay.textContent = String(qty);
    });
  }

  // Image gallery
  const mainImage = document.querySelector('#product-main-image') as HTMLImageElement;
  const thumbnails = document.querySelectorAll('[data-thumb]');

  thumbnails.forEach((thumb) => {
    thumb.addEventListener('click', () => {
      const src = thumb.getAttribute('data-thumb');
      if (src && mainImage) {
        mainImage.src = src;
      }
    });
  });
</script>
