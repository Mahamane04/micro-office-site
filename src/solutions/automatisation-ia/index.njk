<section class="relative overflow-hidden section-pad pb-12">
  {% set mPosition = "right-[-4rem] top-[-4rem] text-ink" %}{% include "partials/motif-arc.njk" %}
  <div class="container-content relative grid grid-cols-1 gap-12 lg:grid-cols-12 lg:items-center">
    <div class="lg:col-span-6">
      <p class="eyebrow"><a href="/solutions/" class="hover:underline">Solutions</a> — 04</p>
      <h1 class="font-heading text-4xl font-bold leading-tight md:text-5xl">Automatisation &amp; intelligence artificielle</h1>
      <p class="mt-6 text-lg leading-relaxed text-ink/70">Réduisez les tâches répétitives et répondez plus rapidement à vos clients.</p>
      <a href="/presenter-mon-projet/" class="btn-primary mt-8">Automatiser mon activité</a>
    </div>
    <div class="lg:col-span-6">
      <div class="relative flex aspect-[4/3] items-center justify-center overflow-hidden bg-ink">
        {% set mPosition = "left-[-2rem] bottom-[-2rem] text-white" %}{% include "partials/motif-diagonal.njk" %}
        <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 64 64" class="h-20 w-20 text-red" fill="none" stroke="currentColor" stroke-width="1.5" aria-hidden="true">
          <path d="M18 44c0-9 6-16 14-16s14 7 14 16" stroke-linecap="round"/>
          <circle cx="32" cy="20" r="7"/>
          <path d="M14 50h36" stroke-linecap="round"/>
        </svg>
      </div>
    </div>
  </div>
</section>

<section class="section-pad border-t border-ink/10">
  <div class="container-content">
    <h2 class="font-heading text-2xl font-bold md:text-3xl">Nos prestations</h2>
    <div class="mt-10 grid grid-cols-1 gap-x-10 gap-y-8 sm:grid-cols-2">
      {% set items = [
        { t: "Chatbot WhatsApp", d: "Un premier contact automatisé, disponible à tout moment." },
        { t: "Assistant commercial", d: "Un accompagnement automatisé de vos prospects." },
        { t: "Qualification des prospects", d: "Identifiez rapidement les demandes prioritaires." },
        { t: "Préparation des devis", d: "Des devis préparés plus rapidement à partir des demandes reçues." },
        { t: "Relances automatiques", d: "Ne perdez plus une opportunité faute de suivi." },
        { t: "Notifications", d: "Restez informé des étapes clés de chaque demande." },
        { t: "Suivi des demandes", d: "Une vue claire sur l'ensemble de vos échanges clients." }
      ] %}
      {% for it in items %}
      <div class="border-t border-ink/10 pt-5">
        <h3 class="font-heading text-base font-semibold">{{ it.t }}</h3>
        <p class="mt-2 text-sm text-ink/60">{{ it.d }}</p>
      </div>
      {% endfor %}
    </div>
  </div>
</section>

