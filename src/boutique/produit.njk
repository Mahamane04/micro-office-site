---
layout: layouts/base.njk
pagination:
  data: produits.produits
  size: 1
  alias: p
permalink: "/boutique/{{ p.slug }}/"
eleventyComputed:
  title: "{{ p.nom }} — {{ p.marque }} | Boutique Micro Office"
  description: "{{ p.accroche }}"
---

<section class="section-pad pb-10">
  <div class="container-content">
    <div><a href="/boutique/" class="tag-mono inline-flex items-center gap-2 text-ink/50 hover:text-red">← Retour à la boutique</a></div>

    <div class="mt-8 grid grid-cols-1 gap-10 lg:grid-cols-2 lg:gap-14"
      data-product-detail
      data-slug="{{ p.slug }}"
      data-nom="{{ p.nom }}"
      data-prix="{{ p.prixPromo if p.prixPromo else p.prix }}"
      data-image="{{ p.couverture }}"
      data-statut="{{ p.statut }}">

      {# Gallery #}
      <div>
        <div class="relative flex aspect-square items-center justify-center overflow-hidden rounded-4xl border border-ink/10 bg-white">
          <img id="product-main-image" src="{{ p.couverture }}" alt="{{ p.nom }}" class="h-full w-full object-contain p-6" loading="eager">
          {% if p.statut == "rupture" %}<span class="product-badge product-badge-out">Rupture</span>
          {% elif p.nouveaute %}<span class="product-badge product-badge-new">Nouveau</span>{% endif %}
        </div>
        {% if p.images and p.images.length > 1 %}
        <div class="mt-3 flex gap-3">
          {% for img in p.images %}
          <button type="button" class="flex aspect-square w-20 items-center justify-center overflow-hidden rounded-2xl border border-ink/10 bg-white transition-colors hover:border-red" data-thumb="{{ img.src }}">
            <img src="{{ img.src }}" alt="{{ img.alt }}" class="h-full w-full object-contain p-1.5" loading="lazy">
          </button>
          {% endfor %}
        </div>
        {% endif %}
      </div>

      {# Info #}
      <div>
        <p class="tag-mono text-red">{{ p.categorie }}</p>
        <h1 class="mt-2 font-heading text-3xl font-bold leading-tight md:text-4xl">{{ p.nom }}</h1>
        <p class="mt-2 text-lg text-ink/50">{{ p.marque }}</p>

        <p class="mt-6 flex items-baseline gap-3 font-heading text-3xl font-bold">
          <span data-price-xof="{{ p.prixPromo if p.prixPromo else p.prix }}">{{ p.prixPromo if p.prixPromo else p.prix }} FCFA</span>
          {% if p.prixPromo %}<span class="text-xl font-medium text-ink/40 line-through" data-price-xof="{{ p.prix }}">{{ p.prix }} FCFA</span>{% endif %}
        </p>

        {# Stock status #}
        <div class="mt-4">
          {% if p.statut == "en stock" %}<span class="pill"><span class="h-2 w-2 rounded-full bg-green-500"></span> En stock</span>
          {% elif p.statut == "sur commande" %}<span class="pill"><span class="h-2 w-2 rounded-full bg-amber-500"></span> Sur commande</span>
          {% else %}<span class="pill"><span class="h-2 w-2 rounded-full bg-ink/40"></span> Rupture de stock</span>{% endif %}
        </div>

        {# Colors #}
        {% if p.couleurs and p.couleurs.length %}
        <div class="mt-8">
          <p class="mb-3 font-heading text-sm font-semibold">Couleur</p>
          <div class="flex flex-wrap gap-2" data-color-group>
            {% for c in p.couleurs %}
            <button type="button" class="group relative flex h-10 w-10 items-center justify-center rounded-full border-2 border-ink/15 transition-transform hover:scale-105 disabled:cursor-not-allowed disabled:opacity-30" data-color="{{ c.nom }}" {% if not c.disponible %}disabled{% endif %} title="{{ c.nom }}" aria-label="Couleur {{ c.nom }}">
              <span class="h-6 w-6 rounded-full ring-1 ring-inset ring-black/10" style="background-color: {{ c.hex }}"></span>
            </button>
            {% endfor %}
          </div>
        </div>
        {% endif %}

        {# Sizes #}
        {% if p.tailles and p.tailles.length %}
        <div class="mt-8">
          <p class="mb-3 font-heading text-sm font-semibold">Taille</p>
          <div class="flex flex-wrap gap-2" data-size-group>
            {% for t in p.tailles %}
            <button type="button" class="min-w-[3rem] rounded-full border border-ink/20 px-4 py-2 font-mono text-[12px] uppercase tracking-wider transition-colors hover:border-ink data-[selected]:border-ink data-[selected]:bg-ink data-[selected]:text-white disabled:cursor-not-allowed disabled:opacity-30 disabled:line-through" data-size="{{ t.valeur }}" {% if not t.disponible %}disabled{% endif %}>{{ t.valeur }}</button>
            {% endfor %}
          </div>
          <p class="mt-2 hidden tag-mono text-red" data-size-error>Veuillez choisir une taille.</p>
        </div>
        {% endif %}

        {# Quantity + actions #}
        <div class="mt-8 flex flex-wrap items-center gap-3">
          <div class="inline-flex items-center rounded-full border border-ink/20">
            <button type="button" class="flex h-11 w-11 items-center justify-center rounded-full text-lg hover:text-red" data-qty-minus aria-label="Diminuer la quantité">−</button>
            <span class="w-8 text-center font-heading font-semibold" data-qty>1</span>
            <button type="button" class="flex h-11 w-11 items-center justify-center rounded-full text-lg hover:text-red" data-qty-plus aria-label="Augmenter la quantité">+</button>
          </div>
          <button type="button" class="btn-primary flex-1 sm:flex-none" data-add-detail {% if p.statut == "rupture" %}disabled{% endif %}>Ajouter au panier</button>
        </div>
        <button type="button" class="btn-secondary mt-3 w-full sm:w-auto" data-order-whatsapp {% if p.statut == "rupture" %}disabled{% endif %}>
          <svg class="h-4 w-4" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true"><path d="M12 2a10 10 0 0 0-8.5 15.3L2 22l4.8-1.5A10 10 0 1 0 12 2Zm5.3 14.1c-.2.6-1.3 1.2-1.8 1.2-.5.1-1 .1-1.7-.1-.4-.1-.9-.3-1.6-.6-2.7-1.2-4.5-4-4.6-4.2-.1-.2-1.1-1.5-1.1-2.8s.7-2 .9-2.2c.2-.2.5-.3.7-.3h.5c.2 0 .4 0 .6.5l.8 2c.1.2.1.3 0 .5l-.4.5-.3.3c-.1.1-.3.3-.1.5.1.3.7 1.1 1.4 1.8 1 .8 1.7 1.1 2 1.2.2.1.4.1.5-.1l.6-.7c.2-.2.3-.2.6-.1l1.9.9c.3.1.4.2.5.3 0 .2 0 .7-.2 1.3Z"/></svg>
          Commander sur WhatsApp
        </button>
        <p class="mt-3 hidden font-mono text-[12px] uppercase tracking-wider text-red" data-detail-stock></p>

        {# Delivery / payment #}
        <div class="mt-8 space-y-3 rounded-3xl border border-ink/10 bg-white p-5">
          <p class="flex items-center gap-3 text-sm text-ink/70"><svg class="h-5 w-5 text-red" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.7" stroke-linecap="round" stroke-linejoin="round"><path d="M1 3h15v13H1z"/><path d="M16 8h4l3 3v5h-7z"/><circle cx="5.5" cy="18.5" r="2.5"/><circle cx="18.5" cy="18.5" r="2.5"/></svg> Livraison Bamako, régions et international (sur devis).</p>
          <p class="flex items-center gap-3 text-sm text-ink/70"><svg class="h-5 w-5 text-red" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.7" stroke-linecap="round" stroke-linejoin="round"><rect x="2" y="5" width="20" height="14" rx="2"/><path d="M2 10h20"/></svg> Paiement à la livraison ou par mobile money.</p>
        </div>

        {% if p.description %}
        <div class="mt-8">
          <h2 class="font-heading text-lg font-bold">Description</h2>
          <p class="mt-3 leading-relaxed text-ink/70">{{ p.description }}</p>
        </div>
        {% endif %}
      </div>
    </div>
  </div>
</section>

{# Related products #}
{% set related = produits.produits | others(p.slug, 4) %}
{% if related.length %}
<section class="section-pad pt-4">
  <div class="container-content">
    <h2 class="font-heading text-2xl font-bold md:text-3xl">Vous aimerez aussi</h2>
    <div class="mt-8 grid grid-cols-1 gap-6 sm:grid-cols-2 lg:grid-cols-4">
      {% for p in related %}{% include "partials/product-card.njk" %}{% endfor %}
    </div>
  </div>
</section>
{% endif %}

<script type="application/ld+json">
{
  "@context": "https://schema.org/",
  "@type": "Product",
  "name": "{{ p.nom }}",
  "image": "{{ site.baseUrl }}{{ p.couverture }}",
  "description": "{{ p.accroche }}",
  "brand": { "@type": "Brand", "name": "{{ p.marque }}" },
  "offers": {
    "@type": "Offer",
    "priceCurrency": "XOF",
    "price": "{{ p.prixPromo if p.prixPromo else p.prix }}",
    "availability": "{{ 'https://schema.org/InStock' if p.statut != 'rupture' else 'https://schema.org/OutOfStock' }}",
    "url": "{{ site.baseUrl }}/boutique/{{ p.slug }}/"
  }
}
</script>
