---
// Decorative diagonal lines, echoes the M of the logo
interface Props {
  position?: string;
}
const { position = 'left-0 bottom-0' } = Astro.props;
---
<svg class={`pointer-events-none absolute ${position} h-40 w-40 opacity-[0.08]`} viewBox="0 0 100 100" fill="none" aria-hidden="true">
  <line x1="0" y1="100" x2="100" y2="0" stroke="currentColor" stroke-width="1"/>
  <line x1="20" y1="100" x2="100" y2="20" stroke="currentColor" stroke-width="1"/>
  <line x1="40" y1="100" x2="100" y2="40" stroke="currentColor" stroke-width="1"/>
</svg>
