---
// Maps a prestation label to a consistent line icon (Feather-style, 24×24,
// stroke=currentColor). Keyword-matched so nothing needs to be set in Airtable.
interface Props {
  label: string;
  class?: string;
}
const { label, class: klass = 'h-6 w-6' } = Astro.props;

// Icon inner markup keyed by a short name
const ICONS: Record<string, string> = {
  logo: '<circle cx="12" cy="12" r="4"/><path d="M12 2v3M12 19v3M2 12h3M19 12h3M5 5l2 2M17 17l2 2M19 5l-2 2M7 17l-2 2"/>',
  palette: '<circle cx="13.5" cy="6.5" r="1"/><circle cx="17.5" cy="10.5" r="1"/><circle cx="8.5" cy="7.5" r="1"/><circle cx="6.5" cy="12.5" r="1"/><path d="M12 2C6.5 2 2 6 2 11c0 3.9 3.1 7 7 7 1.1 0 1.5-.9 1.5-1.6 0-.4-.2-.7-.4-1-.3-.3-.5-.7-.5-1.1 0-.8.7-1.5 1.5-1.5H13c3.9 0 7-3.1 7-7 0-3.9-3.6-6.8-8-6.8Z"/>',
  sign: '<path d="M12 3v3"/><rect x="4" y="6" width="16" height="6" rx="1"/><path d="M9 12v3a3 3 0 0 0 6 0v-3"/><path d="M8 20h8"/>',
  storefront: '<path d="M3 9l1.5-4.5A1 1 0 0 1 5.4 4h13.2a1 1 0 0 1 .95.7L21 9"/><path d="M3 9v0a3 3 0 0 0 6 0 3 3 0 0 0 6 0 3 3 0 0 0 6 0"/><path d="M5 11v9h14v-9"/><path d="M9 20v-5h6v5"/>',
  building: '<rect x="4" y="3" width="16" height="18" rx="1"/><path d="M9 7h2M13 7h2M9 11h2M13 11h2M9 15h2M13 15h2"/><path d="M10 21v-3h4v3"/>',
  booth: '<path d="M6 21V7l6-3 6 3v14"/><path d="M6 7h12"/><path d="M12 7v14"/><path d="M4 21h16"/>',
  cube: '<path d="M12 2 3 7v10l9 5 9-5V7l-9-5Z"/><path d="M3 7l9 5 9-5"/><path d="M12 12v10"/>',
  poster: '<rect x="4" y="3" width="16" height="18" rx="1"/><circle cx="9" cy="9" r="1.5"/><path d="M4 16l4-3 3 2 4-4 5 4"/>',
  share: '<circle cx="6" cy="12" r="2.5"/><circle cx="18" cy="6" r="2.5"/><circle cx="18" cy="18" r="2.5"/><path d="M8.2 10.9l7.6-3.8M8.2 13.1l7.6 3.8"/>',
  video: '<rect x="2" y="5" width="14" height="14" rx="2"/><path d="M22 8l-6 4 6 4V8Z"/>',
  book: '<path d="M4 5a2 2 0 0 1 2-2h6v16H6a2 2 0 0 0-2 2V5Z"/><path d="M20 5a2 2 0 0 0-2-2h-6v16h6a2 2 0 0 1 2 2V5Z"/>',
  card: '<rect x="2" y="5" width="20" height="14" rx="2"/><circle cx="7.5" cy="11" r="2"/><path d="M13 9h5M13 13h5"/>',
  flyer: '<path d="M6 2h8l4 4v14a1 1 0 0 1-1 1H6a1 1 0 0 1-1-1V3a1 1 0 0 1 1-1Z"/><path d="M14 2v4h4"/><path d="M8 12h8M8 16h5"/>',
  box: '<path d="M12 2 3 7v10l9 5 9-5V7l-9-5Z"/><path d="M3 7l9 5 9-5M12 12v10M7.5 4.5l9 5"/>',
  gift: '<rect x="3" y="8" width="18" height="4" rx="1"/><path d="M5 12v8a1 1 0 0 0 1 1h12a1 1 0 0 0 1-1v-8"/><path d="M12 8v13"/><path d="M12 8S10 3 7.5 4.5 9 8 12 8Zm0 0s2-5 4.5-3.5S15 8 12 8Z"/>',
  monitor: '<rect x="2" y="4" width="20" height="13" rx="2"/><path d="M8 21h8M12 17v4"/><path d="M2 9h20"/><circle cx="5" cy="6.5" r=".6"/>',
  cart: '<circle cx="9" cy="20" r="1.4"/><circle cx="17" cy="20" r="1.4"/><path d="M2 3h2.2l2.1 12.2a1 1 0 0 0 1 .8h9.4a1 1 0 0 0 1-.8L20 7H5.5"/>',
  phone: '<rect x="6" y="2" width="12" height="20" rx="2.5"/><path d="M10 18h4"/>',
  portal: '<rect x="4" y="3" width="16" height="18" rx="1.5"/><path d="M14 3v18"/><circle cx="9" cy="12" r="1.4"/>',
  users: '<circle cx="9" cy="8" r="3"/><path d="M3 20a6 6 0 0 1 12 0"/><path d="M16 5.5a3 3 0 0 1 0 5.5M21 20a6 6 0 0 0-4-5.6"/>',
  clipboard: '<rect x="6" y="4" width="12" height="17" rx="2"/><path d="M9 4a1.5 1.5 0 0 1 1.5-1.5h3A1.5 1.5 0 0 1 15 4v1H9V4Z"/><path d="M9 11h6M9 15h4"/>',
  payment: '<rect x="2" y="5" width="20" height="14" rx="2"/><path d="M2 10h20"/><path d="M6 15h4"/>',
  stock: '<rect x="3" y="13" width="8" height="8" rx="1"/><rect x="13" y="13" width="8" height="8" rx="1"/><rect x="8" y="3" width="8" height="8" rx="1"/>',
  dashboard: '<rect x="3" y="3" width="18" height="18" rx="2"/><path d="M8 16v-4M12 16V9M16 16v-6"/>',
  chat: '<path d="M4 5a2 2 0 0 1 2-2h12a2 2 0 0 1 2 2v8a2 2 0 0 1-2 2H9l-4 4v-4H6a2 2 0 0 1-2-2V5Z"/><path d="M8 9h8M8 12h5"/>',
  bot: '<rect x="5" y="8" width="14" height="10" rx="3"/><path d="M12 4v4M9 4.5h6"/><circle cx="9.5" cy="13" r="1"/><circle cx="14.5" cy="13" r="1"/>',
  funnel: '<path d="M3 5h18l-7 8v6l-4 2v-8L3 5Z"/>',
  quote: '<path d="M6 2h9l4 4v13a1 1 0 0 1-1 1H6a1 1 0 0 1-1-1V3a1 1 0 0 1 1-1Z"/><path d="M15 2v4h4"/><path d="M9 13h6M9 16h4M9 10h3"/>',
  refresh: '<path d="M3 12a9 9 0 0 1 15-6.7L21 8"/><path d="M21 3v5h-5"/><path d="M21 12a9 9 0 0 1-15 6.7L3 16"/><path d="M3 21v-5h5"/>',
  bell: '<path d="M6 9a6 6 0 0 1 12 0c0 5 2 6 2 6H4s2-1 2-6Z"/><path d="M10 20a2 2 0 0 0 4 0"/>',
  track: '<circle cx="12" cy="12" r="3"/><path d="M2 12h3M19 12h3M12 2v3M12 19v3"/><circle cx="12" cy="12" r="8" stroke-dasharray="2 3"/>',
  spark: '<path d="M12 3l1.8 5.2L19 10l-5.2 1.8L12 17l-1.8-5.2L5 10l5.2-1.8L12 3Z"/>',
};

// Ordered keyword → icon matching (first match wins)
const MATCHERS: [RegExp, string][] = [
  [/logo/, 'logo'],
  [/identit|visuel|charte/, 'palette'],
  [/enseigne/, 'sign'],
  [/fa[çc]ade|devanture/, 'storefront'],
  [/bureau|boutique|int[ée]rieur/, 'building'],
  [/stand/, 'booth'],
  [/3d|visualis/, 'cube'],
  [/affiche/, 'poster'],
  [/r[ée]seau|social/, 'share'],
  [/vid[ée]o/, 'video'],
  [/catalogue/, 'book'],
  [/carte de visite|carte/, 'card'],
  [/flyer|dépliant|depliant/, 'flyer'],
  [/packaging|emballage/, 'box'],
  [/objet|personnalis|goodies/, 'gift'],
  [/e-?commerce|boutique en ligne/, 'cart'],
  [/application|appli|mobile/, 'phone'],
  [/portail|espace client/, 'portal'],
  [/gestion des client|relation client|clients/, 'users'],
  [/commande/, 'clipboard'],
  [/paiement/, 'payment'],
  [/stock/, 'stock'],
  [/tableau|dashboard|bord/, 'dashboard'],
  [/site|pr[ée]sentation|web|internet/, 'monitor'],
  [/chatbot|whatsapp|message/, 'chat'],
  [/assistant|commercial/, 'bot'],
  [/qualif|prospect/, 'funnel'],
  [/devis/, 'quote'],
  [/relance/, 'refresh'],
  [/notification/, 'bell'],
  [/suivi|demande/, 'track'],
];

function pickIcon(label: string): string {
  const l = label.toLowerCase();
  for (const [re, key] of MATCHERS) {
    if (re.test(l)) return key;
  }
  return 'spark';
}

const inner = ICONS[pickIcon(label)];
---
<svg
  viewBox="0 0 24 24"
  fill="none"
  stroke="currentColor"
  stroke-width="1.6"
  stroke-linecap="round"
  stroke-linejoin="round"
  class={klass}
  aria-hidden="true"
  set:html={inner}
/>
