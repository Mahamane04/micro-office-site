{
  "name": "site",
  "version": "1.0.0",
  "description": "",
  "main": "index.js",
  "scripts": {
    "css:build": "tailwindcss -i ./src/css/tailwind.css -o ./src/css/output.css --minify",
    "css:watch": "tailwindcss -i ./src/css/tailwind.css -o ./src/css/output.css --watch",
    "eleventy:build": "eleventy",
    "eleventy:watch": "eleventy --serve",
    "build": "npm run css:build && npm run eleventy:build",
    "dev": "npm run css:build && concurrently \"npm:css:watch\" \"npm:eleventy:watch\"",
    "admin": "npm run css:build && concurrently \"npm:css:watch\" \"npm:eleventy:watch\" \"decap-server\"",
    "netlify": "netlify dev"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "dependencies": {
    "@supabase/supabase-js": "^2.45.4"
  },
  "devDependencies": {
    "@11ty/eleventy": "^3.1.6",
    "@tailwindcss/typography": "^0.5.20",
    "autoprefixer": "^10.5.4",
    "concurrently": "^10.0.3",
    "decap-server": "^3.9.1",
    "netlify-cli": "^17.36.1",
    "postcss": "^8.5.19",
    "tailwindcss": "^3.4.19"
  }
}
