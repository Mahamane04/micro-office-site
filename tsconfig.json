{
  "extends": "astro/tsconfigs/strict",
  "compilerOptions": {
    "jsxImportSource": "react",
    "baseUrl": ".",
    "paths": {
      "@components/*": ["src/components/*"],
      "@layouts/*": ["src/layouts/*"],
      "@lib/*": ["src/lib/*"],
      "@styles/*": ["src/styles/*"],
      "@images/*": ["src/images/*"],
      "@public/*": ["public/*"]
    },
    "strictNullChecks": true,
    "noEmit": true,
    "moduleResolution": "bundler"
  }
}
