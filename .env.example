# Variables d'environnement — Boutique dynamique
# Copiez ce fichier en `.env` (local) ou définissez ces variables dans Netlify.
# SANS ces variables, les fonctions tournent en MODE MOCK (données simulées) —
# pratique pour tester le site avant de brancher Supabase.

# Projet Supabase (Settings → API)
SUPABASE_URL=
SUPABASE_SERVICE_KEY=
SUPABASE_ANON_KEY=

# Mot de passe du mini-admin des commandes (/admin-commandes/)
ADMIN_PASSWORD=change-moi
