# Variables d'environnement — Micro Office (Astro + Airtable + ISR)
# Copiez ce fichier en `.env.local` pour développement local.
# En production, définissez ces variables dans les settings Netlify.

# ========== AIRTABLE CMS ==========
# Airtable API Token (Settings → Developer Hub → Tokens)
AIRTABLE_API_TOKEN=pat_xxxxx

# Base ID (Settings → API → Base ID)
AIRTABLE_BASE_ID=appXxxxx

# Table names
AIRTABLE_TABLE_PRODUITS=Produits
AIRTABLE_TABLE_PORTFOLIO=Projets
AIRTABLE_TABLE_CONFIG=Configuration

# ========== CLOUDINARY (Images) ==========
# Cloudinary account details
CLOUDINARY_CLOUD_NAME=microoffice
CLOUDINARY_API_KEY=xxxxx
CLOUDINARY_API_SECRET=xxxxx

# ========== SUPABASE (Commandes existantes) ==========
# Supabase project URL
SUPABASE_URL=https://xxxxx.supabase.co

# Service role key (for backend functions)
SUPABASE_SERVICE_KEY=xxxxx

# Anon key (for client-side)
SUPABASE_ANON_KEY=xxxxx

# ========== NETLIFY (ISR Webhooks) ==========
# Netlify ISR webhook secret (generate random string)
NETLIFY_ISR_SECRET=webhook_secret_xxxxx

# Netlify site ID (Settings → General → Site ID)
NETLIFY_SITE_ID=xxxxx

# Netlify auth token (for CI/CD)
NETLIFY_AUTH_TOKEN=xxxxx

# ========== FEATURE FLAGS ==========
# Use Astro (true) or fallback to Eleventy (false)
USE_ASTRO=true

# Build mode for debugging
BUILD_MODE=astro

# ========== SITE METADATA ==========
# Production site URL
SITE_URL=https://www.microofficeml.com

# Site name for SEO/branding
SITE_NAME="Micro Office"

# ========== ADMIN ==========
# Mini-admin password for /admin-commandes/
ADMIN_PASSWORD=change-moi
